{
    "name": "the-great-escape",
    "version": "1.0.0",
    "description": "The Great Escape — Travel Planning App",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:nonvisual": "playwright test --grep-invert='Visual regression'",
        "test:e2e:visual": "playwright test tests/e2e/visual.spec.js",
        "test:e2e:visual:update": "playwright test tests/e2e/visual.spec.js --update-snapshots",
        "prepare": "husky"
    },
    "lint-staged": {
        "frontend/static/js/src/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "tests/e2e/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "{playwright,vite,eslint}.config.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,css}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.10"
    },
    "dependencies": {
        "zod": "^4.4.3"
    }
}
