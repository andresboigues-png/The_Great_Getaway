{
    "name": "the-great-escape",
    "version": "1.0.0",
    "description": "The Great Escape — Travel Planning App",
    "type": "module",
    "scripts": {
        "build": "vite build && node scripts/prune-dead-chunks.mjs --apply",
        "build:no-prune": "vite build",
        "prune": "node scripts/prune-dead-chunks.mjs --apply",
        "prune:check": "node scripts/prune-dead-chunks.mjs",
        "watch": "vite build --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:ci": "eslint . --quiet",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:nonvisual": "playwright test --grep-invert='Visual regression'",
        "test:e2e:visual": "playwright test tests/e2e/visual.spec.js",
        "test:e2e:visual:update": "playwright test tests/e2e/visual.spec.js --update-snapshots",
        "test:e2e:a11y": "playwright test tests/e2e/a11y.spec.js",
        "build:analyze": "ANALYZE=1 vite build",
        "check:bundle-size": "node scripts/check-bundle-size.mjs",
        "prepare": "husky",
        "test:unit:coverage": "vitest run --coverage"
    },
    "lint-staged": {
        "frontend/static/js/src/**/*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "frontend/static/js/src/**/*.{ts,tsx}": [
            "prettier --write"
        ],
        "tests/e2e/**/*.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "{playwright,vite,eslint}.config.{js,ts}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,css}": [
            "prettier --write"
        ],
        "{src,tests,migrations}/**/*.py": [
            "python3 -m ruff check --fix",
            "python3 -m ruff format"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@axe-core/cli": "^4.11.3",
        "@axe-core/playwright": "^4.11.3",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/vite": "^4.3.0",
        "@types/google.maps": "^3.65.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.9",
        "chart.js": "^4.5.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.1.1",
        "fast-check": "^4.8.0",
        "flag-icons": "^7.5.0",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.10",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "exifr": "^7.1.3",
        "flatpickr": "^4.6.13",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
    }
}
