# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Project-specific
.vscode/
.idea/
*.log

# Distribution / packaging
dist/
build/
*.egg-info/
travel_planner.db
ngrok*.zip
ngrok
node_modules/
frontend/static/js/app.bundle.js.map
# D5: code-split chunk source maps. Same convention as app.bundle.js.map —
# chunk JS is committed (build artefact deployed alongside the entry),
# but the matching .map files are dev-only and bloat the repo.
frontend/static/js/chunks/*.map
# User uploads — dev/test artifact only. Production deploys override
# UPLOAD_FOLDER via GG_UPLOAD_ROOT (per src/main.py:60-65) to a path
# OUTSIDE the cloned repo so user-uploaded photos survive code redeploys
# (git pull / wipe-and-reclone). Locally, every Playwright run that
# exercises /api/upload (photo-exif, photo-lightbox, photo-drag-reorder)
# leaves an owner-<random>/ subdirectory here; manual testing leaves
# its own. None of it should ever be committed.
frontend/static/uploads/
# D5: bundle visualizer output, emitted only when ANALYZE=1 and only
# read locally for performance audits.
bundle-stats.html

# OS junk
.DS_Store
**/.DS_Store

# Claude Code local state
.claude/

# Local databases (SQLite) + their backups / WAL sidecars.
# NOTE: `*.db` does NOT match a `.db.bak` suffix — the missing `.bak`
# pattern is exactly how two DB backups (with a live API key + user PII)
# got committed and pushed (MK6 P0). Keep every SQLite artifact ignored.
*.db
*.db.bak
*.bak
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
src/database.db

# Scratch / experimental data
scratch/
.husky/_

# Audit reports — findings-only working docs, kept untracked (MK5/MK6 convention).
*audit MK*.md
Audit MK*.md

# Playwright artifacts
test-results/
playwright-report/

# pytest-cov binary data + html report (regenerated on every CI run)
.coverage
htmlcov/
.pytest_cache/
run-dev.sh
